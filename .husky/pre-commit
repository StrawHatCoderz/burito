#!/bin/sh

echo "=== Running Pre-Commit Test Suite ==="

# 1. Run Backend Checks
echo "--- [1/3] Running Backend Linting (Checkstyle - Warnings Only) ---"
cd backend
./gradlew checkstyleMain --no-daemon
cd ..

echo "--- [2/3] Running Backend Tests ---"
cd backend
./gradlew test --no-daemon
BACKEND_TEST_EXIT=$?
if [ $BACKEND_TEST_EXIT -ne 0 ]; then
  echo "❌ Backend tests failed! Aborting commit."
  exit 1
fi
cd ..

# 2. Run Frontend Checks
echo "--- [3/3] Running Frontend Tests ---"
cd frontend
npm run test
FRONTEND_TEST_EXIT=$?
if [ $FRONTEND_TEST_EXIT -ne 0 ]; then
  echo "❌ Frontend tests failed! Aborting commit."
  exit 1
fi
cd ..

echo "=== ✅ All Pre-Commit Test Suites Passed! ==="
exit 0
